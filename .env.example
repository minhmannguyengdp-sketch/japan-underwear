# Local server: port 3000 is forbidden for this project.
DEV_PORT=3100

# PostgreSQL / Heroku Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/japan_underwear
DB_POOL_MAX=5

# Local catalog sources (keep outside the repository)
LOCAL_TT_ROOT=F:\\1_A_Disk_D\\TT
LOCAL_WINKING_IMAGES=F:\\1_A_Disk_D\\TT\\WK_1600
LOCAL_PENSEE_IMAGES=F:\\1_A_Disk_D\\TT\\pensee_1600
LOCAL_QL_IMAGES=F:\\1_A_Disk_D\\TT\\QL
LOCAL_PRICE_FILE=F:\\1_A_Disk_D\\TT\\Bang_bao_gia_Winking_Pensee.xlsx
LOCAL_CATALOG_MANIFEST=F:\\1_A_Disk_D\\TT\\japan-underwear\\data\\local\\catalog-manifest.json

# Cloudflare R2. Real secrets belong only in .env.local.
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket jurisdiction: default, eu, or fedramp.
R2_JURISDICTION=default

# Optional full S3 endpoint override. Normally leave empty.
# Example: https://<ACCOUNT_ID>.eu.r2.cloudflarestorage.com
R2_ENDPOINT=

# Optional public/custom domain without trailing slash, for example:
# https://cdn.example.com
R2_PUBLIC_BASE_URL=

# Object keys are generated under this prefix.
R2_PREFIX=catalog

# Parallel uploads. Keep modest on a normal Windows connection.
R2_UPLOAD_CONCURRENCY=4
