{
  "name": "japan-underwear",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "build": "next build",
    "start": "node scripts/start-server.mjs",
    "lint": "eslint .",
    "catalog:manifest": "node scripts/catalog/build-price-authoritative-manifest.mjs",
    "catalog:audit": "node scripts/catalog/audit-price-authoritative-catalog.mjs",
    "catalog:web:audit": "node scripts/catalog/consolidate-tuan-thuy-order-audit.mjs",
    "catalog:web:review": "node scripts/catalog/build-tuan-thuy-review-plan.mjs",
    "catalog:web:approve": "node scripts/catalog/approve-tuan-thuy-order-data.mjs",
    "catalog:web:import": "node scripts/catalog/import-tuan-thuy-order-data.mjs",
    "catalog:sync": "node scripts/catalog/sync-active-catalog.mjs",
    "catalog:r2:upload": "node scripts/catalog/upload-r2.mjs",
    "catalog:db:import": "node scripts/catalog/import-postgres.mjs",
    "catalog:bootstrap": "npm run db:migrate && node scripts/catalog/bootstrap-postgres.mjs",
    "catalog:go": "npm run dev",
    "r2:diagnose": "node scripts/r2/diagnose.mjs",
    "r2:check": "node scripts/r2/check.mjs",
    "db:baseline": "node scripts/db/baseline-existing-catalog.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate && node scripts/db/apply-order-variant-identity.mjs",
    "db:repair-enum": "node scripts/db/repair-catalog-enum.mjs",
    "db:repair-product-identity": "node scripts/db/apply-product-identity.mjs",
    "db:repair-order-variant": "node scripts/db/apply-order-variant-identity.mjs",
    "db:verify": "node scripts/db/verify-catalog-migration.mjs",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "latest",
    "dotenv": "latest",
    "drizzle-orm": "latest",
    "next": "latest",
    "pg": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/pg": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "drizzle-kit": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "latest",
    "tailwindcss": "latest",
    "typescript": "latest"
  }
}
